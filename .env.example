# Default lookback window in days — used when --since is not passed
# Change this to suit your workflow (7 = weekly, 30 = monthly)
SINCE_DEFAULT=7

# Maximum issues to fetch per run — directly controls cost
# Lower this for very active repos (e.g. 100) to cap spend
MAX_ISSUES=500

# LiteLLM model string — controls which LLM is used
# Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514
# OpenAI:    gpt-4o, gpt-4o-mini
# Gemini:    gemini/gemini-1.5-pro
LITELLM_MODEL=claude-sonnet-4-20250514

# API key for whichever provider your model uses
# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# GitHub token — optional, raises rate limit from 60 to 5000/hr
# Create at: https://github.com/settings/tokens — no scopes needed for public repos
GITHUB_TOKEN=
