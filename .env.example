# ── Provider selection ────────────────────────────────────────────────────────
# Which provider to use by default. Overridden at runtime with --provider.
# Options: claude | gpt | gemini
DEFAULT_PROVIDER=claude

# Model to use for each provider.
# Change these to switch models without touching the code.
# Anthropic models: https://docs.anthropic.com/en/docs/about-claude/models
MODEL_CLAUDE=claude-sonnet-4-20250514

# OpenAI models: https://platform.openai.com/docs/models
MODEL_OPENAI=gpt-4o

# Google Gemini models (prefix with gemini/): https://ai.google.dev/gemini-api/docs/models
MODEL_GEMINI=gemini/gemini-1.5-pro

# ── API keys ──────────────────────────────────────────────────────────────────
# Only the key for your active provider is required.
# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────────
# Optional — raises rate limit from 60 to 5000 requests/hour.
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Default lookback window in days — used when --since is not passed.
SINCE_DEFAULT=7

# Maximum issues to fetch per run — directly controls cost.
MAX_ISSUES=500
